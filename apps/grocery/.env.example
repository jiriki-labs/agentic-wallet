# Grocery402 local config (copy to .env in this directory).
# Loaded by the Nest API on startup (apps/grocery/api/src/load-env.ts).

# x402 payTo — wallet that receives USDC for ingredient orders
MERCHANT_ADDR=0x0000000000000000000000000000000000000000

# Optional
# GROCERY_MERCHANT_ADDR=0x...
# GROCERY_PUBLIC_URL=http://127.0.0.1:4402
# GROCERY_SKIP_X402_VERIFY=1
# X402_FACILITATOR_URL=https://x402.org/facilitator
# PORT=4402
# DEBUG=1
